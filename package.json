{
  "name": "ink-battles-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "scripts": {
    "dev": "turbo run dev --filter=@ink-battles/frontend --filter=@ink-battles/backend",
    "dev:all": "turbo run dev --filter=@ink-battles/frontend --filter=@ink-battles/backend",
    "build": "turbo run build",
    "build:all": "turbo run build",
    "build:docker": "docker compose -f docker-compose.yml -f docker-compose.build.yml build",
    "build:docker:frontend": "docker compose -f docker-compose.yml -f docker-compose.build.yml build frontend",
    "build:docker:backend": "docker compose -f docker-compose.yml -f docker-compose.build.yml build backend",
    "start": "pnpm run frontend:start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "frontend:dev": "pnpm --filter @ink-battles/frontend dev",
    "frontend:build": "pnpm --filter @ink-battles/frontend build",
    "frontend:start": "pnpm --filter @ink-battles/frontend start",
    "frontend:lint": "eslint frontend",
    "frontend:typecheck": "pnpm --filter @ink-battles/frontend typecheck",
    "backend:dev": "pnpm --filter @ink-battles/backend dev",
    "backend:build": "pnpm --filter @ink-battles/backend build",
    "backend:start": "pnpm --filter @ink-battles/backend start",
    "backend:typecheck": "pnpm --filter @ink-battles/backend typecheck",
    "compose:config": "docker compose config",
    "compose:pull": "docker compose pull",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:restart": "docker compose restart",
    "compose:logs": "docker compose logs -f",
    "compose:ps": "docker compose ps"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.3.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@unocss/eslint-plugin": "^66.6.8",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "turbo": "^2.9.16"
  }
}
